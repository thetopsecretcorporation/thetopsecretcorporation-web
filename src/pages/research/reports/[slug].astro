---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const reports = Object.values(import.meta.glob('../../../content/researchReports/*.md', { eager: true }));

  return reports
    .filter((report) => !report.frontmatter.draft)
    .map((report) => ({
      params: {
        slug: report.file.split(/[\\/]/).pop()?.replace(/\.md$/i, ''),
      },
      props: { report },
    }));
}

const { report } = Astro.props;

function normalizePublishDate(value: string | number | Date) {
  if (value instanceof Date) {
    return value;
  }

  if (typeof value === 'string') {
    const isoDateMatch = value.match(/^(\d{4})-(\d{2})-(\d{2})/);

    if (isoDateMatch) {
      const [, year, month, day] = isoDateMatch;
      return new Date(Number(year), Number(month) - 1, Number(day));
    }
  }

  return new Date(value);
}

const publishDate = normalizePublishDate(report.frontmatter.publishDate);
const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(publishDate);
const AuthorName = report.frontmatter.author.replace(/^By\s+/i, '');
const tags = report.frontmatter.tags ?? [];
const taxonomy = tags.join(' / ');
const Content = report.Content;
---
<BaseLayout title={`${report.frontmatter.title} | Research | The Top Secret Corporation`} description={report.frontmatter.summary}>
  <section class="archive-hero report-hero">
    <div class="container report-shell-outer">
      <div class="copy-stack archive-copy report-shell">
        <span class="eyebrow">Research briefing</span>
        <h1>{report.frontmatter.title}</h1>
        <p class="page-intro-body report-abstract">{report.frontmatter.summary}</p>
        <div class="archive-meta report-meta" aria-label="Report metadata">
          <div class="report-meta-row">
            <span class="report-publication-date">{formattedDate}</span>
            <span class="report-meta-separator" aria-hidden="true">/</span>
            <span>{`By ${AuthorName}`}</span>
            {taxonomy ? (
              <>
                <span class="report-meta-separator" aria-hidden="true">/</span>
                <span class="report-taxonomy" aria-label="Report tags">{taxonomy}</span>
              </>
            ) : null}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="report-reading-section">
    <div class="container report-reading-shell">
      <article class="report-reading-field">
        <div class="report-prose article-prose">
          <Content />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
