---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { researchContent } from '../../lib/site';

type ResearchReportCard = {
  slug: string;
  href: string;
  title: string;
  description: string;
  date: string;
  displayDate: string;
  author: string;
  tags: string[];
};

function getReportSlug(entry: { file?: string }) {
  const slug = entry.file?.split(/[\\/]/).pop()?.replace(/\.md$/i, '');

  if (!slug) {
    throw new Error('Unable to derive research report slug from markdown entry.');
  }

  return slug;
}

function parsePublishDate(value: string | number | Date) {
  if (value instanceof Date) {
    return value;
  }

  if (typeof value === 'string') {
    const isoDateMatch = value.match(/^(\d{4})-(\d{2})-(\d{2})/);

    if (isoDateMatch) {
      const [, year, month, day] = isoDateMatch;
      return new Date(Number(year), Number(month) - 1, Number(day));
    }
  }

  return new Date(value);
}

const markdownEntries = Object.values(import.meta.glob('../../content/researchReports/*.md', { eager: true }));

const reports: ResearchReportCard[] = markdownEntries
  .filter((entry) => !entry.frontmatter.draft)
  .map((entry) => {
    const publishDate = parsePublishDate(entry.frontmatter.publishDate);
    const slug = getReportSlug(entry);

    return {
      slug,
      href: `/research/reports/${slug}/`,
      title: entry.frontmatter.title,
      description: entry.frontmatter.summary,
      date: publishDate.toISOString().slice(0, 10),
      displayDate: new Intl.DateTimeFormat('en-US', {
        month: 'long',
        day: 'numeric',
        year: 'numeric',
      }).format(publishDate),
      author: entry.frontmatter.author.startsWith('By ') ? entry.frontmatter.author : `By ${entry.frontmatter.author}`,
      tags: entry.frontmatter.tags ?? [],
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date) || b.slug.localeCompare(a.slug));
---
<BaseLayout title={`Research Archive | The Top Secret Corporation`} description="Research briefings and field reports from The Top Secret Corporation.">
  <section class="archive-header">
    <div class="container archive-shell">
      <div class="copy-stack archive-copy page-intro-copy">
        <span class="eyebrow">{researchContent.eyebrow}</span>
        <h1>{researchContent.title}</h1>
        <p class="page-intro-body">{researchContent.body}</p>
        <p class="archive-meta" aria-label="Archive metadata">
          <span>{reports.length} {reports.length === 1 ? 'report' : 'reports'}</span>
          <span class="archive-meta-separator" aria-hidden="true">/</span>
          <span>{researchContent.orderedLabel}</span>
        </p>
      </div>
    </div>
  </section>

  <section class="reports-section">
    <div class="container archive-shell">
      {reports.length ? (
        <div class="reports-grid">
          {reports.map((report) => (
            <article class="report-card">
              <a class="report-card-link" href={report.href} aria-label={`Read ${report.title}`}>
                <div class="report-card-topline">
                  <span class="report-date">{report.displayDate}</span>
                </div>
                <div class="report-card-heading">
                  <h2>{report.title}</h2>
                </div>
                <p class="report-summary">{report.description}</p>
                <div class="meta-row" aria-label="Report metadata">
                  <span>{report.author}</span>
                  {report.tags.length ? <span>{report.tags.slice(0, 2).join(' / ')}</span> : null}
                </div>
                <span class="report-link">Read briefing</span>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">{researchContent.emptyMessage}</div>
      )}
    </div>
  </section>
</BaseLayout>
